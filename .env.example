# Secrets — copy to .env and fill in. .env is git-ignored.
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME
TELEGRAM_BREAKOUT_CHAT_ID=-1000000000000
TELEGRAM_NEWS_CHAT_ID=-1000000000000
# Optional residential proxy for IDX/Yahoo egress (leave blank to use the host IP):
IDX_PROXY=
# Orderbook "Ready Markup" alert (optional; only needed if orderbook.enabled: true).
# STOCKBIT_REFRESH_TOKEN: your Stockbit refresh token (grey-area vs Stockbit ToS) —
#   used for unattended operation (mints access tokens automatically).
# STOCKBIT_ACCESS_TOKEN: optional; paste a current access token to test the data
#   path immediately without the refresh flow (JWT; expires per its own exp claim).
#   NEVER put a real token here — this file is committed. Put it in .env instead.
# TELEGRAM_ORDERBOOK_CHAT_ID: falls back to TELEGRAM_BREAKOUT_CHAT_ID if left blank.
STOCKBIT_REFRESH_TOKEN=
STOCKBIT_ACCESS_TOKEN=
TELEGRAM_ORDERBOOK_CHAT_ID=
